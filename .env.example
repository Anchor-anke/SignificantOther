# Database — SQLite for local dev
# 注意：Prisma CLI 读取 .env；Next.js 读取 .env.local
# 本地开发请把 DATABASE_URL 写在 .env（Prisma 用）和 .env.local（可选，Next 用）中
DATABASE_URL="file:./dev.db"

# Production (Vercel + PostgreSQL)
# DATABASE_URL="postgresql://user:password@host:5432/significant_other?schema=public"

# DeepSeek API (DeepSeek-V4-Flash)
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Zhipu GLM Vision API (GLM-4V-Flash)
GLM_API_KEY="your-glm-api-key"
GLM_API_URL="https://open.bigmodel.cn/api/paas/v4"
GLM_VISION_MODEL="glm-4v-flash"
